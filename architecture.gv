digraph SeedifyArchitecture {
    rankdir=TB;
    bgcolor="#0a0e27";
    fontname="Helvetica";
    pad="0.8,0.8";
    nodesep=1.2;
    ranksep=0.8;
    splines=true;
    
    node [
        shape=box,
        style="filled,rounded",
        fontname="Helvetica-Bold",
        fontsize=13,
        fontcolor="white",
        color="transparent",
        margin="0.25,0.15"
    ];
    
    edge [
        penwidth=2.0,
        fontname="Helvetica",
        fontsize=10,
        fontcolor="#aaaaaa",
        arrowsize=0.9
    ];
    
    // Title
    title [label="🌲  SEEDIFY — System Architecture · April 2026", shape=none, fontsize=22, fontcolor="#00ff88"];
    
    // ===== TIER 1: User Interfaces =====
    pwa [label="🌐 React PWA\nNext.js · TS · Tailwind · Vercel", fillcolor="#1a3a5c"];
    telegram [label="📱 Telegram Bot\nOpenClaw Channel", fillcolor="#1a3a5c"];
    
    // ===== TIER 2: Core Orchestration =====
    agent [label="🧠 OpenClaw Agent\nOrchestrator · Sessions · Heartbeat · Tool Calling", fillcolor="#2a1a4e"];
    
    // ===== TIER 3: Backend + Scheduler =====
    fastapi [label="⚡ FastAPI Backend\nJWT Auth · Streaming · Tool Execution\nEnrichment Bridge · Port 8000", fillcolor="#0d2b3e"];
    cron [label="⏰ Cron Scheduler\n12 Active Jobs", fillcolor="#2a1a4e"];
    
    // ===== TIER 4: Data Stores =====
    weaviate [label="🔍 Weaviate\nVector Search · IdeaSeed\nSemantic · Tenant Isolation · :8080", fillcolor="#0d2b3e"];
    postgres [label="🐘 PostgreSQL 15\nUsers · Ratings · Auth\n:5432", fillcolor="#0d2b3e"];
    redis [label="📦 Redis 7\nQueues · Caching · :6379", fillcolor="#0d2b3e"];
    
    // ===== TIER 5: Pipeline =====
    voice [label="🎙️ Voice Memo → 📝 Transcribe → 🅿️ Notion Parking Lot", fillcolor="#0d3320"];
    enrich [label="🧬 Enrichment Pipeline\nChunk · Extract · Backlink · Re-embed · Monitor", fillcolor="#0d3320"];
    garden [label="🌱 Idea Garden\nNemotron Synthesis · BFL Concept Maps", fillcolor="#0d3320"];
    
    // ===== TIER 6: External Services =====
    openrouter [label="🤖 OpenRouter\nNemotron · GPT-4o-mini", fillcolor="#3a2a00"];
    openai [label="🧩 OpenAI Embeddings", fillcolor="#3a2a00"];
    notion [label="📋 Notion API\nPKM · Journal · Seeds", fillcolor="#3a2a00"];
    exa [label="🔎 Exa Search", fillcolor="#3a2a00"];
    bfl [label="🎨 BFL Images", fillcolor="#3a2a00"];
    
    // ===== CONNECTIONS =====
    pwa -> fastapi [color="#00ff88", xlabel="REST / WebSocket"];
    telegram -> agent [color="#00ff88"];
    
    agent -> fastapi [color="#bb88ff", xlabel="tool calls"];
    agent -> cron [color="#bb88ff", xlabel="dispatch"];
    cron -> agent [color="#bb88ff", xlabel="systemEvents"];
    
    fastapi -> weaviate [color="#00d4ff", xlabel="GraphQL"];
    fastapi -> postgres [color="#00d4ff", xlabel="SQLAlchemy"];
    fastapi -> redis [color="#00d4ff", xlabel="jobs"];
    
    voice -> enrich [color="#00ff88"];
    enrich -> weaviate [color="#00ff88", xlabel="embed + store"];
    enrich -> garden [color="#00ff88"];
    garden -> notion [color="#00ff88", xlabel="sync"];
    
    fastapi -> openrouter [color="#ffaa00", xlabel="LLM"];
    fastapi -> openai [color="#ffaa00", xlabel="embed"];
    fastapi -> exa [color="#ffaa00", xlabel="search"];
    fastapi -> bfl [color="#ffaa00", xlabel="images"];
    fastapi -> notion [color="#ffaa00", xlabel="CRUD"];
    enrich -> openrouter [color="#ffaa00", style=dashed];
    
    // Legend + Status
    l1 [label="🟢 User / Data Flows", shape=none, fontsize=10, fontcolor="#00ff88"];
    l2 [label="🟣 Agent Comms", shape=none, fontsize=10, fontcolor="#bb88ff"];
    l3 [label="🔵 Database Queries", shape=none, fontsize=10, fontcolor="#00d4ff"];
    l4 [label="🟡 External APIs", shape=none, fontsize=10, fontcolor="#ffaa00"];
    { rank=same; l1; l2; l3; l4; }
    l1 -> l2 -> l3 -> l4 [style=invis];
    
    status [label="✅ All Services Healthy  ·  Docker Compose  ·  Hetzner Server", 
            shape=none, fontsize=11, fontcolor="#00ff88"];
}
