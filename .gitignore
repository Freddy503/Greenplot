# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.pyc
__pycache__/
backups/
openclaw-api/app/*.bak
# Runtime data files — server-only, never overwrite on git pull
openclaw-api/data/push_notifications.json
openclaw-api/data/push_subscriptions.json

# Local agent/tooling dirs — never commit
.claude/
.clawhub/
.openclaw/
.superset/
logs/
outputs/
AGENTS.md

# Generated/private knowledge base content. Keep these in runtime storage or a
# private backup, not in the public application repository.
wiki/
openclaw-api/wiki/
public/wiki-images/
openclaw-api/public/wiki-images/
data/
openclaw-api/data/
