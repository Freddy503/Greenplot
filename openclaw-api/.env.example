# Deploy
# Which published image tag the server runs. Defaults to `latest`. Pin to a
# commit SHA (e.g. sha-<full-hash>, as tagged by CI) to deploy/rollback a
# specific build:  IMAGE_TAG=sha-abc123 docker compose up -d
IMAGE_TAG=latest

# FastAPI
SECRET_KEY=replace-with-a-random-32-byte-hex-value

# Database
POSTGRES_PASSWORD=replace-with-a-strong-local-password
DATABASE_URL=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@db:5432/openclaw
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@db:5432/openclaw

# Weaviate
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_CLASS=AppSeed

# Redis
REDIS_URL=redis://redis:6379/0

# LLM & Research APIs
OPENAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
EXA_API_KEY=
# Groq Whisper for voice transcription (10× faster STT). Blank → falls back to
# OpenAI Whisper via OPENAI_API_KEY. Read by app/ingest.py.
GROQ_API_KEY=

# Email (Resend) — get key at resend.com, verify domain digest@greenplot.ink
RESEND_API_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback

# Web Push (VAPID)
VAPID_PRIVATE_KEY_BASE64=...

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional public/contact settings
CONTACT_EMAIL=
DEFAULT_CITY=Munich
OPENALEX_MAILTO=
ADMIN_EMAILS=
INVITE_CODES=
GITHUB_REPO=

# --- Optional: Neo4j context graph (traversal index after semantic retrieval) ---
# Postgres stays the source of truth; Neo4j is an opt-in projection. The feature
# only activates when BOTH NEO4J_ENABLED=true AND NEO4J_PASSWORD is set, AND the
# DB container is started with its profile:  docker compose --profile graph up -d
# NOTE: NEO4J_PASSWORD also seeds the neo4j container's auth on its FIRST boot
# only — it is persisted in the neo4j_data volume. Changing it later requires
# wiping that volume, or auth will fail.
NEO4J_ENABLED=false
NEO4J_PASSWORD=
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j
NEO4J_SYNC_ON_RETRIEVE=false
NEO4J_MAX_SYNC_SEEDS=1000
# Min Weaviate certainty for a semantic edge to be projected into Neo4j on sync.
# Lower = denser graph (more, weaker links); higher = sparser/stronger. Re-run
# /graph/neo4j/sync after changing. 0.80 is a good starting point.
NEO4J_SEMANTIC_CERTAINTY_MIN=0.80
