# FastAPI
SECRET_KEY=your-secret-key-change-this

# Database
DATABASE_URL=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@db:5432/openclaw
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@db:5432/openclaw

# Weaviate
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_CLASS=AppSeed

# Redis
REDIS_URL=redis://redis:6379/0

# LLM & Research APIs
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
NVIDIA_API_KEY=<NVIDIA_API_KEY>
EXA_API_KEY=...
BFL_API_KEY=<BFL_API_KEY>

# Email (Resend) — get key at resend.com, verify domain digest@greenplot.ink
RESEND_API_KEY=re_...

# Google Calendar OAuth
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
GOOGLE_REDIRECT_URI=https://api.greenplot.ink/api/v1/calendar/callback

# Web Push (VAPID)
VAPID_PRIVATE_KEY_BASE64=...

# Frontend
FRONTEND_URL=https://greenplot.ink
CORS_ORIGINS=https://greenplot.ink,https://www.greenplot.ink,https://api.greenplot.ink
